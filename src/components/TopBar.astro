---
import { site } from '../site.config';
import Pulse from './Pulse.astro';

interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;
const live = site.live.on;
---
<div class="topbar">
  {live && (
    <a class="livebar" href={site.live.youtubeUrl} target="_blank" rel="noopener">
      <Pulse color="#ff6159" />
      <span class="live-title">Live on YouTube · "{site.live.classTitle}"</span>
      <span class="live-cta">Watch →</span>
    </a>
  )}

  <div class="bar">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true"></span>
      R. Mitchell
    </a>

    <nav class="rm-desktop-nav nav">
      {site.nav.map((item) => (
        <a
          href={item.href}
          class:list={["nav-link", { active: active === item.key }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="actions">
      <button
        class="theme-toggle"
        type="button"
        aria-label="Toggle colour theme"
        title="Toggle colour theme"
      >
        <span class="lbl lbl-dark">Dark</span>
        <span class="lbl lbl-light">Light</span>
      </button>

      <button
        class="rm-mobile-toggle mtoggle"
        type="button"
        aria-expanded="false"
        aria-controls="rm-mobile-menu"
      >
        Menu
      </button>
    </div>
  </div>

  <div id="rm-mobile-menu" class="mobile-menu" hidden>
    {site.nav.map((item, i) => (
      <a
        href={item.href}
        class:list={["mobile-link", { active: active === item.key }]}
      >
        <span>{item.label}</span>
        <span class="mobile-num">0{i + 1}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
  }
  .livebar {
    background: var(--ink);
    color: var(--paper);
    padding: 7px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    text-decoration: none;
  }
  .livebar .live-cta {
    margin-left: auto;
    opacity: 0.7;
  }

  .bar {
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .brand {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .brand-mark {
    width: 10px;
    height: 10px;
    background: var(--accent);
    display: inline-block;
  }

  .nav {
    gap: 26px;
  }
  .nav-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    color: var(--ink);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
  }
  .nav-link.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .actions {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .theme-toggle,
  .mtoggle {
    background: transparent;
    border: 1px solid var(--rule);
    padding: 7px 11px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--ink);
    cursor: pointer;
    font-weight: 500;
    transition: border-color 120ms, color 120ms;
  }
  .theme-toggle:hover,
  .mtoggle:hover {
    border-color: var(--ink);
  }

  /* Show only the label matching the NEXT theme (what you'll switch to).
     Dark is the default, so by default we show "Light". */
  .lbl-dark {
    display: none;
  }
  :global(:root[data-theme="light"]) .lbl-dark {
    display: inline;
  }
  :global(:root[data-theme="light"]) .lbl-light {
    display: none;
  }

  .mobile-menu {
    padding: 6px 20px 18px;
    border-top: 1px solid var(--rule);
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-link {
    display: flex;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--hairline);
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    color: var(--ink);
  }
  .mobile-link.active {
    color: var(--accent);
  }
  .mobile-num {
    font-size: 10px;
    opacity: 0.5;
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.rm-mobile-toggle');
  const menu = document.getElementById('rm-mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      const next = !isOpen;
      toggle.setAttribute('aria-expanded', String(next));
      toggle.textContent = next ? 'Close' : 'Menu';
      if (next) {
        menu.removeAttribute('hidden');
      } else {
        menu.setAttribute('hidden', '');
      }
    });
  }

  const themeBtn = document.querySelector<HTMLButtonElement>('.theme-toggle');
  themeBtn?.addEventListener('click', () => {
    // Dark is the site default, so "no attribute" means dark
    const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try {
      localStorage.setItem('rm-theme', next);
    } catch {
      /* storage blocked — session-only theme */
    }
  });
</script>
