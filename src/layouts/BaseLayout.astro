---
import '../styles/tokens.css';
import '../styles/global.css';
import { site } from '../site.config';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';

// Inline flash-prevention script — runs synchronously in <head> before
// any body paint. Applies the user's saved theme (if any); otherwise
// dark is the site default and comes straight from tokens.css.
const themeInit = `(function(){try{var s=localStorage.getItem('rm-theme');if(s)document.documentElement.setAttribute('data-theme',s);}catch(e){}})();`;

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
  screenLabel?: string;
}

const {
  title = site.title,
  description = site.description,
  pageKey = 'home',
  screenLabel,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <script is:inline set:html={themeInit} />
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

  </head>
  <body data-screen-label={screenLabel}>
    {/* Netlify detects these forms at deploy time; kept hidden but parsed */}
    <form name="contact" data-netlify="true" netlify-honeypot="bot-field" hidden>
      <input type="text" name="name" />
      <input type="email" name="email" />
      <input type="text" name="topic" />
      <textarea name="note"></textarea>
    </form>
    <form name="newsletter" data-netlify="true" netlify-honeypot="bot-field" hidden>
      <input type="email" name="email" />
      <input type="text" name="source" />
    </form>

    <TopBar active={pageKey} />
    <main class="rm-page-anim">
      <slot />
    </main>
    <Footer />
  </body>
</html>
