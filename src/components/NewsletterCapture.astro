---
import Tick from './Tick.astro';

interface Props {
  source: string;
  eyebrow: string;
  heading: string;
  cta?: string;
  meta?: string;
}
const {
  source,
  eyebrow,
  heading,
  cta = 'Save seat →',
  meta,
} = Astro.props;
---
<div class="nc">
  <div class="top">
    <Tick color="rgba(255,255,255,0.6)">{eyebrow}</Tick>
    {meta && <Tick color="rgba(255,255,255,0.6)">{meta}</Tick>}
  </div>

  <div class="headline" set:html={heading} />

  <form
    class="form"
    name="newsletter"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    action="/thanks/"
  >
    <input type="hidden" name="form-name" value="newsletter" />
    <input type="hidden" name="source" value={source} />
    <p class="hp"><label>Don't fill this out: <input name="bot-field" /></label></p>

    <div class="field">
      <input
        type="email"
        name="email"
        required
        placeholder="you@domain.com"
        autocomplete="email"
      />
      <button type="submit">{cta}</button>
    </div>
  </form>
</div>

<style>
  .nc {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(28px, 4vw, 44px);
  }
  .top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .headline {
    font-family: var(--display);
    font-size: clamp(20px, 2.6vw, 30px);
    line-height: 1.15;
    letter-spacing: -0.03em;
    font-weight: 500;
    text-transform: uppercase;
    margin: 0 0 22px;
    text-wrap: balance;
    max-width: 620px;
  }
  .form {
    max-width: 460px;
  }
  .field {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--paper);
    transition: border-color 150ms;
  }
  .field:focus-within {
    border-color: var(--accent);
  }
  input[type="email"] {
    flex: 1;
    border: none;
    background: transparent;
    padding: 10px 0;
    font-size: 16px;
    color: var(--paper);
    font-family: var(--sans);
    outline: none;
    min-width: 0;
  }
  input[type="email"]::placeholder {
    color: rgba(238, 241, 244, 0.45);
  }
  button {
    border: none;
    background: transparent;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--paper);
    padding: 0 4px;
    cursor: pointer;
    white-space: nowrap;
  }
</style>
