---
interface Props {
  color?: string;
}
const { color = 'var(--accent)' } = Astro.props;
---
<span class="pulse" style={`--pulse-color: ${color}`} aria-hidden="true">
  <span class="pulse-core"></span>
  <span class="pulse-ring"></span>
</span>

<style>
  .pulse {
    position: relative;
    width: 7px;
    height: 7px;
    display: inline-block;
  }
  .pulse-core {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--pulse-color);
  }
  .pulse-ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: var(--pulse-color);
    opacity: 0.35;
    animation: rmpulse 1.6s ease-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .pulse-ring {
      animation: none;
    }
  }
</style>
