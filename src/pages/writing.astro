---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tick from '../components/Tick.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.order - a.data.order,
);
const tags = ['All', 'Essay', 'Playbook', 'Note'] as const;
---
<BaseLayout
  pageKey="writing"
  title="Writing — Essays, Playbooks, Notes | Robert Mitchell"
  description="Every class becomes a written post. Skim the index, or filter by type."
  screenLabel="04 Writing"
>
  <section class="intro">
    <Tick>Document / 004 / Writing</Tick>
    <h1 class="h1">Written<br />versions.</h1>
    <p class="sub">
      Every class becomes a written post. Skim the index, or filter by type.
    </p>
  </section>

  <section class="filters" aria-label="Filter posts by tag">
    {tags.map((t, i) => (
      <button
        type="button"
        class:list={["filter-btn", { active: i === 0 }]}
        data-filter={t}
      >
        {t}
      </button>
    ))}
  </section>

  <section class="index" data-posts>
    {posts.map((p) => (
      <a class="post" href="/writing/" data-tag={p.data.tag}>
        <Tick color="var(--accent)">{p.data.num}</Tick>
        <div class="post-body">
          <div class="post-tag"><Tick>{p.data.tag}</Tick></div>
          <div class="post-title">{p.data.title}</div>
          <div class="post-excerpt">{p.data.excerpt}</div>
        </div>
        <div class="post-meta">
          <Tick block>{p.data.date}</Tick>
          <Tick block>{p.data.read}</Tick>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .intro {
    padding: clamp(48px, 8vw, 84px) clamp(20px, 4vw, 56px) clamp(28px, 4vw, 40px);
  }
  .intro :global(.tick) {
    display: block;
    margin-bottom: 24px;
  }
  .h1 {
    font-family: var(--display);
    font-size: clamp(32px, 5.5vw, 64px);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 500;
    margin: 0;
    text-transform: uppercase;
    color: var(--ink);
    text-wrap: balance;
  }
  .sub {
    margin-top: 24px;
    font-family: var(--sans);
    font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.55;
    color: var(--subtle);
    max-width: 560px;
    text-wrap: pretty;
  }

  .filters {
    padding: 0 clamp(20px, 4vw, 56px) 20px;
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--rule);
  }
  .filter-btn {
    background: transparent;
    border: none;
    padding: 10px 16px 10px 0;
    margin-right: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    cursor: pointer;
    font-weight: 500;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    margin-bottom: -1px;
    transition: color 120ms;
  }
  .filter-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .index {
    padding: 0 clamp(20px, 4vw, 56px) clamp(40px, 7vw, 72px);
  }
  .post {
    display: grid;
    grid-template-columns: clamp(48px, 6vw, 72px) 1fr auto;
    gap: clamp(12px, 2vw, 24px);
    padding: clamp(18px, 2.5vw, 22px) 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    text-decoration: none;
    color: inherit;
    transition: padding-left 160ms;
  }
  .post:hover {
    padding-left: 10px;
  }
  .post-tag {
    margin-bottom: 10px;
  }
  .post-title {
    font-family: var(--display);
    font-size: clamp(17px, 2vw, 22px);
    line-height: 1.2;
    letter-spacing: -0.03em;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 10px;
    text-wrap: balance;
  }
  .post-excerpt {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--subtle);
    line-height: 1.5;
    max-width: 540px;
    text-wrap: pretty;
  }
  .post-meta {
    text-align: right;
  }
  .post-meta :global(.tick + .tick) {
    margin-top: 6px;
    color: var(--muted);
  }
  .post.hidden {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const posts = document.querySelectorAll<HTMLElement>('[data-posts] .post');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => b.classList.toggle('active', b === btn));
      posts.forEach((p) => {
        const match = filter === 'All' || p.dataset.tag === filter;
        p.classList.toggle('hidden', !match);
      });
    });
  });
</script>
